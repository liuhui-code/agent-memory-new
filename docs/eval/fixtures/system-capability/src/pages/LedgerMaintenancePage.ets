  private async commitSelectedLedgerBatch(): Promise<void> {
    if (this.pendingCount === 0) {
      return
    }
    await LedgerStore.validatePendingBatch()
    await LedgerStore.commitPendingBatch()
    this.pendingCount = 0
    this.statusText = 'ledger batch committed'
  }

  build() {
    Button('Commit selected ledger batch')
      .onClick(() => {
        this.commitSelectedLedgerBatch()
      })
    Text(this.statusText)
  }
